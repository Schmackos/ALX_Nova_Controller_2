%% Slot-Indexed Sink Dispatch — Audio Output Path
%% Pipeline iterates ALL slots (0..3), skipping empty/not-ready/muted

flowchart LR
    subgraph matrix["Post-Matrix Output"]
        OUT["_outCh[0..7]\n8 mono float32 channels\n256 frames each"]
    end

    subgraph dispatch["Slot-Indexed Dispatch Loop"]
        direction TB
        LOOP["for slot = 0..3"]
        CHK1{"_sinks[slot].write\n!= NULL?"}
        CHK2{"isReady()?"}
        CHK3{"!muted?"}
        GAIN{"gainLinear\n!= 1.0?"}
        APPLY["Apply gain +\nclamp to [-1,1]"]
        CONV["float32 -> int32\nleft-justified (<<8)"]
        WRITE["sink->write(\n  buf, frames\n)"]
        SKIP["Skip slot\n(no dispatch)"]

        LOOP --> CHK1
        CHK1 -->|"NULL"| SKIP
        CHK1 -->|"valid"| CHK2
        CHK2 -->|"false"| SKIP
        CHK2 -->|"true"| CHK3
        CHK3 -->|"muted"| SKIP
        CHK3 -->|"active"| GAIN
        GAIN -->|"yes"| APPLY --> CONV
        GAIN -->|"unity"| CONV
        CONV --> WRITE
    end

    subgraph sinks["Sink Slots (AudioOutputSink[4])"]
        S0["Slot 0: PCM5102A\nfirstChannel=0, chCount=2\nhalSlot=0"]
        S1["Slot 1: ES8311\nfirstChannel=2, chCount=2\nhalSlot=1"]
        S2["Slot 2: (empty)\nwrite=NULL"]
        S3["Slot 3: (empty)\nwrite=NULL"]
    end

    subgraph hw["Hardware"]
        I2S0["I2S0 TX\nGPIO 24"]
        I2S2["I2S2 TX\nES8311 codec"]
    end

    OUT -->|"channels 0,1"| S0
    OUT -->|"channels 2,3"| S1
    S0 --> LOOP
    S1 --> LOOP
    WRITE -->|"slot 0"| I2S0
    WRITE -->|"slot 1"| I2S2

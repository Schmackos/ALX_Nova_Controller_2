%% Slot-Indexed Sink Dispatch — Audio Output Path
%% Pipeline iterates ALL slots (0..7), skipping empty/not-ready/muted

flowchart LR
    subgraph matrix["Post-Matrix Output"]
        OUT["_outCh[0..15]\n16 mono float32 channels\n256 frames each"]
    end

    subgraph dispatch["Slot-Indexed Dispatch Loop"]
        direction TB
        LOOP["for slot = 0..7"]
        CHK1{"_sinks[slot].write\n!= NULL?"}
        CHK2{"isReady()?"}
        CHK3{"!muted?"}
        GAIN{"gainLinear\n!= 1.0?"}
        APPLY["Apply gain +\nclamp to [-1,1]"]
        CONV["float32 -> int32\nleft-justified (<<8)"]
        WRITE["sink->write(\n  buf, frames\n)"]
        SKIP["Skip slot\n(no dispatch)"]

        LOOP --> CHK1
        CHK1 -->|"NULL"| SKIP
        CHK1 -->|"valid"| CHK2
        CHK2 -->|"false"| SKIP
        CHK2 -->|"true"| CHK3
        CHK3 -->|"muted"| SKIP
        CHK3 -->|"active"| GAIN
        GAIN -->|"yes"| APPLY --> CONV
        GAIN -->|"unity"| CONV
        CONV --> WRITE
    end

    subgraph sinks["Sink Slots (AudioOutputSink[8])"]
        S0["Slot 0: DAC output\nfirstChannel=0, chCount=2\nhalSlot=N\n(e.g. PCM5102A by default)"]
        S1["Slot 1: DAC output\nfirstChannel=2, chCount=2\nhalSlot=N\n(e.g. ES8311 by default)"]
        S2["Slot 2..7: additional outputs\nassigned by HAL bridge\nordinal counting (HAL_CAP_DAC_PATH)"]
    end

    subgraph hw["Hardware"]
        I2S0["I2S0 TX\nGPIO 24"]
        I2S2["I2S2 TX\nES8311 codec"]
        EXT["Future outputs\n(MCP4725, etc.)"]
    end

    OUT -->|"channels 0,1"| S0
    OUT -->|"channels 2,3"| S1
    OUT -->|"channels 4+"| S2
    S0 --> LOOP
    S1 --> LOOP
    S2 --> LOOP
    WRITE -->|"slot 0"| I2S0
    WRITE -->|"slot 1"| I2S2
    WRITE -->|"slot 2+"| EXT
